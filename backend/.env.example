# ---------------------------------------------------------------------------
# HRMS Backend — environment configuration template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# App
APP_NAME=HRMS
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:8100,http://localhost:3000

# Database (async SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://hrms:hrms@localhost:5432/hrms
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (cache + event broker + job queue)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Auth / JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900             # seconds (15 min)
REFRESH_TOKEN_TTL=1209600        # seconds (14 days)

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@hrms.local

# File storage / uploads
STORAGE_BACKEND=local            # local | s3
UPLOAD_DIR=var/uploads
MAX_UPLOAD_SIZE_MB=10

# Background jobs
QUEUE_BACKEND=redis
WORKER_CONCURRENCY=4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json | console

# WebSockets
WS_PATH=/ws
