# ---------------------------------------------------------------------------
# HRMS Backend — environment configuration template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# App
APP_NAME=HRMS
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:8100,http://localhost:3000

# Database (async SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://hrms:hrms@localhost:5432/hrms
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (cache + event broker + job queue)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Auth / JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900             # seconds (15 min)
REFRESH_TOKEN_TTL=1209600        # seconds (14 days)

# Rate limiting / brute-force protection (Redis-backed; auth endpoints)
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=10         # requests per window, per IP and per email
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
REFRESH_RATE_LIMIT_ATTEMPTS=30       # requests per window, per IP
REFRESH_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_MAX_FAILED_ATTEMPTS=5          # consecutive failures before account lockout
LOGIN_FAILURE_WINDOW_SECONDS=900     # seconds (15 min) the failure streak is kept
LOGIN_LOCKOUT_SECONDS=900            # seconds (15 min) an account stays locked

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@hrms.local

# File storage / uploads
STORAGE_BACKEND=local            # local | s3
UPLOAD_DIR=var/uploads
MAX_UPLOAD_SIZE_MB=10

# Background jobs (arq worker: `make worker`)
QUEUE_BACKEND=redis
WORKER_CONCURRENCY=4
JOB_MAX_TRIES=3                  # attempts per job before it is abandoned
JOB_TIMEOUT_SECONDS=300
JOB_RESULT_TTL_SECONDS=86400
LEAVE_ACCRUAL_CRON_HOUR=1        # nightly leave accrual (worker local time)
LEAVE_ACCRUAL_CRON_MINUTE=30
DEVICE_SYNC_INTERVAL_MINUTES=15  # device sync runs every N minutes
SCHEDULER_ENABLED=true           # false = worker drains the queue but runs no cron

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json | console

# WebSockets
WS_PATH=/ws
